{% assign img_path = include.path | remove: '.jpg' | remove: '.jpeg' | remove: '.png' | remove: '.tiff' | remove: '.gif' %}
{% assign parts = include.path | split: '.' %}
{% assign ext = parts.last %}
{% assign figure_min_width = include['min-width'] | safe_css_dimension %}
{% assign figure_min_height = include['min-height'] | safe_css_dimension %}
{% assign figure_max_width = include['max-width'] | safe_css_dimension %}
{% assign figure_max_height = include['max-height'] | safe_css_dimension %}

<figure
  {% if include.slot %}
    slot="{{ include.slot | escape }}"
  {% endif %}
  >
  <picture>
    <img
      src="{% if include.url %}{{ include.url | escape }}{% elsif include.cache_bust %}{{ include.path | relative_url | bust_file_cache | escape }}{% else %}{{ include.path | relative_url | escape }}{% endif %}"
      {% if site.imagemagick.enabled and include.avoid_scaling != true %}
        {% if ext == 'gif' or ext == 'jpeg' or ext == 'jpg' or ext == 'png' or ext == 'tiff' %}
          srcset="{% for i in site.imagemagick.widths %}{{ img_path | relative_url }}-{{ i }}.webp {{ i }}w{% unless forloop.last %}, {% endunless %}{% endfor %}"
        {% else %}
          srcset="{{ include.path | relative_url | escape }}"
        {% endif %}
        {% if include.sizes %}
          sizes="{{ include.sizes | escape }}"
        {% else %}
          sizes="95vw"
        {% endif %}
      {% endif %}
      {% if include.class %}
        class="{{ include.class | escape }}"
      {% endif %}
      {% if include.width %}
        width="{{ include.width | escape }}"
      {% endif %}
      {% if include.height %}
        height="{{ include.height | escape }}"
      {% endif %}
      {% if figure_min_width and figure_min_width != empty or figure_min_height and figure_min_height != empty or figure_max_width and figure_max_width != empty or figure_max_height and figure_max_height != empty %}
        style="
          {% if figure_min_width and figure_min_width != empty %}
            min-width: {{ figure_min_width | escape }};
          {% endif %}
          {% if figure_min_height and figure_min_height != empty %}
            min-height: {{ figure_min_height | escape }};
          {% endif %}
          {% if figure_max_width and figure_max_width != empty %}
            max-width: {{ figure_max_width | escape }};
          {% endif %}
          {% if figure_max_height and figure_max_height != empty %}
            max-height: {{ figure_max_height | escape }};
          {% endif %}
        "
      {% endif %}
      alt="{{ include.alt | default: '' | escape }}"
      {% if include.title %}
        title="{{ include.title | escape }}"
      {% endif %}
      {% if include.zoomable %}
        data-zoomable
      {% endif %}
      {% if include.loading %}
        loading="{{ include.loading | escape }}"
      {% elsif site.lazy_loading_images %}
        loading="lazy"
      {% endif %}
      onerror="this.onerror=null; this.removeAttribute('srcset');"
    >
  </picture>

  {% if include.caption %}
    <figcaption class="caption">{{ include.caption }}</figcaption>
  {% endif %}
</figure>
