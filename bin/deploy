#!/usr/bin/env bash
set -euo pipefail

if [[ "${1:-}" == "-h" || "${1:-}" == "--help" ]]; then
  cat <<'USAGE'
Usage: bin/deploy

Build the production Pages artifact locally in _site/. Publishing is handled
by .github/workflows/deploy.yml; this command never changes branches or pushes.
USAGE
  exit 0
fi

if (( $# > 0 )); then
  echo "bin/deploy does not accept build options: $*" >&2
  exit 2
fi

export JEKYLL_ENV=production
bundle exec jekyll build --destination _site

echo "Production artifact built in _site/."
echo "GitHub Pages publishing is handled by .github/workflows/deploy.yml."
