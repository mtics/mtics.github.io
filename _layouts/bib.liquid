---
---
{% assign entry_dom_id = entry.key | safe_publication_dom_id %}
{% assign doi_id = entry.doi | normalize_doi %}
{% assign arxiv_id = entry.arxiv | safe_publication_identifier %}
{% assign hal_id = entry.hal | safe_publication_identifier %}
{% assign video_url = entry.video | safe_link_url %}
<div class="row">
  {% if site.enable_publication_thumbnails %}
    <div class="col col-sm-2 abbr">
      {%- if entry.abbr -%}
        {%- if site.data.venues[entry.abbr] -%}
          {% assign venue_color = site.data.venues[entry.abbr].color | safe_css_color %}
          {% assign venue_url = site.data.venues[entry.abbr].url | safe_http_url %}
          <abbr
            class="badge rounded w-100"
            {% if venue_color and venue_color != empty %}
              style="background-color: {{ venue_color | escape }}"
            {% endif -%}
          >
            {% if venue_url and venue_url != empty %}
              <a href="{{ venue_url | escape }}">{{ entry.abbr | escape }}</a>
            {% else %}
              <div>{{- entry.abbr | escape -}}</div>
            {% endif %}
          </abbr>
        {% else %}
          <abbr class="badge rounded w-100">{{ entry.abbr | escape }}</abbr>
        {% endif %}
      {% endif %}
      {% if entry.preview %}
        {% assign preview_alt = entry.title | strip_html %}
        {% assign preview_url = entry.preview | safe_http_url %}
        {% assign preview_path = entry.preview | safe_local_asset_path %}
        {% if preview_url and preview_url != empty %}
          <img class="preview z-depth-1 rounded" src="{{ preview_url | escape }}" alt="{{ preview_alt | escape }}">
        {% elsif preview_path and preview_path != empty %}
          {% assign entry_path = preview_path | prepend: '/assets/img/publication_preview/' %}
          {%
            include figure.liquid
            loading="eager"
            path=entry_path
            sizes = "200px"
            class="preview z-depth-1 rounded"
            zoomable=true
            avoid_scaling=true
            alt=preview_alt
          %}
        {% endif %}
      {% endif %}
    </div>
  {% endif %}

  <!-- Entry bib key -->
  <div id="{{ entry_dom_id | escape }}" class="{% if site.enable_publication_thumbnails %}col-sm-8{% else %}col-sm-10{% endif %}">
    <!-- Title -->
    <div class="title">{{ entry.title }}</div>
    <!-- Author -->
    <div class="author">
      {% assign author_array_size = entry.author_array | size %}

      {% assign author_array_limit = author_array_size %}
      {% if site.max_author_limit and author_array_size > site.max_author_limit %}
        {% assign author_array_limit = site.max_author_limit %}
      {% endif %}

      {%- for author in entry.author_array limit: author_array_limit -%}
        {% assign author_is_self = false %}
        {%- assign author_last_name = author.last | regex_replace: '[*∗†‡§¶‖&^]', '' -%}
        {%- assign author_last_html = author.last | escape | regex_replace: '([*∗†‡§¶‖^]+)$', '<sup>\1</sup>' | regex_replace: '(&amp;)$', '<sup>\1</sup>' -%}
        {% if site.scholar.last_name contains author_last_name %}
          {% if site.scholar.first_name contains author.first %}
            {% assign author_is_self = true %}
          {% endif %}
        {%- endif -%}
        {% assign coauthor_url = null %}
        {%- assign clean_last_name = author_last_name | downcase | remove_accents -%}
        {% if site.data.coauthors[clean_last_name] %}
          {%- for coauthor in site.data.coauthors[clean_last_name] -%}
            {% if coauthor.firstname contains author.first %}
              {%- assign coauthor_url = coauthor.url | safe_http_url -%}
              {% break %}
            {%- endif -%}
          {% endfor %}
        {%- endif -%}

        {%- if forloop.length > 1 -%}
          {% if forloop.first == false -%}
            {%- if forloop.length > 2 %}, {% elsif forloop.length == 2 %}  {% endif %}
          {%- endif %}
          {%- if forloop.last and author_array_limit == author_array_size %}and {% endif -%}
        {% endif %}
        {%- if author_is_self -%}
          <em>
            {{- author.first | escape }}
            {{ author_last_html -}}
          </em>
        {%- else -%}
          {%- if coauthor_url and coauthor_url != empty -%}
            <a href="{{ coauthor_url | escape }}">
              {{- author.first | escape }}
              {{ author_last_html -}}
            </a>
          {%- else -%}
            {{- author.first | escape }}
            {{ author_last_html -}}
          {% endif %}
        {%- endif -%}
      {% endfor %}
      {%- assign more_authors = author_array_size | minus: author_array_limit -%}

      {%- assign more_authors_hide = more_authors | append: ' more author' -%}
      {% if more_authors > 0 %}
        {%- if more_authors > 1 -%}
          {% assign more_authors_hide = more_authors_hide | append: 's' %}
        {%- endif -%}
        , and
        <button
          type="button"
          class="more-authors"
          data-more-authors-toggle
          aria-expanded="false"
          aria-label="Show {{ more_authors_hide }}"
        >
          <span data-more-authors-collapsed>{{- more_authors_hide -}}</span>
          <span data-more-authors-expanded hidden>
            {%- for author in entry.author_array offset: author_array_limit -%}
              {%- assign more_author_last = author.last | escape | regex_replace: '([*∗†‡§¶‖^]+)$', '<sup>\1</sup>' | regex_replace: '(&amp;)$', '<sup>\1</sup>' -%}
              {{- author.first | escape }} {{ more_author_last -}}
              {%- unless forloop.last %}, {% endunless -%}
            {%- endfor -%}
          </span>
        </button>
      {% endif %}
      {% if entry.annotation %}
        <details class="publication-annotation d-inline-block ml-1">
          <summary aria-label="Publication note" style="display: inline; list-style: none; cursor: pointer;">
            <i class="fa-solid fa-circle-info" aria-hidden="true"></i>
            <span class="sr-only">Publication note</span>
          </summary>
          <span class="publication-annotation-content" role="note">{{ entry.annotation | escape }}</span>
        </details>
      {% endif %}
    </div>

    <!-- Journal/Book title and date -->
    {% assign proceedings = 'inproceedings,incollection' | split: ',' %}
    {% assign thesis = 'thesis,mastersthesis,phdthesis' | split: ',' %}
    {% if entry.type == 'article' %}
      {% capture entrytype %}<em>{{ entry.journal }}</em>{% endcapture %}
    {% elsif proceedings contains entry.type %}
      {% capture entrytype %}<em>In {{ entry.booktitle }}</em>{% endcapture %}
    {% elsif thesis contains entry.type %}
      {% capture entrytype %}<em>{{ entry.school }}</em>{% endcapture %}
    {% else %}
      {% capture entrytype %}{% endcapture %}
    {% endif %}
    {% assign entrymonth = '' %}
    {% if entry.month %}
      {% capture entrymonth %}{{ " " }}{{ entry.month | capitalize }}{% endcapture %}
    {% endif %}
    {% assign entryyear = '' %}
    {% if entry.year %}
      {% capture entryyear %}{{ " " }}{{ entry.year }}{% endcapture %}
    {% endif %}
    {% if entry.location %}
      {% capture entrytype %}{{ entrytype }}{{ ", " }}{{ entry.location }}{% endcapture %}
    {% endif -%}
    {% if entry.additional_info %}
      {% capture entrytype %}{{ entrytype }}{{ entry.additional_info | markdownify | remove: '<p>' | remove: '</p>' }}{% endcapture %}
    {% endif %}
    {% capture hook_exists %}{% file_exists _includes/hook/bib.liquid %}{% endcapture %}
    {% if hook_exists == 'true' %}
      {% include hook/bib.liquid %}
    {% endif %}
    {% assign entrytype_text = entrytype | strip_html | strip %}
    {% capture periodical %}{{ entrytype }}{% if entrytype_text != "" and entryyear != "" %}, {% endif %}{{ entrymonth }}{{ entryyear }}{% endcapture %}
    <div class="periodical">
      {{ periodical | strip }}
    </div>
    <div class="periodical">
      {{ entry.note | strip }}
    </div>

    <!-- Links/Buttons -->
    <div class="links">
      {% if entry.award %}
        <a
          href="#{{ entry_dom_id | escape }}-award"
          class="award btn btn-sm z-depth-0"
          role="button"
          data-bib-disclosure
          aria-controls="{{ entry_dom_id | escape }}-award"
          aria-expanded="false"
        >
          {%- if entry.award_name %}{{ entry.award_name }}{% else %}Awarded{% endif -%}
        </a>
      {% endif %}
      {% if entry.abstract %}
        <a
          href="#{{ entry_dom_id | escape }}-abstract"
          class="abstract btn btn-sm z-depth-0"
          role="button"
          data-bib-disclosure
          aria-controls="{{ entry_dom_id | escape }}-abstract"
          aria-expanded="false"
        >Abs</a>
      {% endif %}
      {% if doi_id and doi_id != empty %}
        <a href="https://doi.org/{{ doi_id | escape }}" class="btn btn-sm z-depth-0">DOI</a>
      {% endif %}
      {% if arxiv_id and arxiv_id != empty %}
        <a href="https://arxiv.org/abs/{{ arxiv_id | escape }}" class="btn btn-sm z-depth-0">arXiv</a>
      {% endif %}
      {% if hal_id and hal_id != empty %}
        <a href="https://hal.science/{{ hal_id | escape }}" class="btn btn-sm z-depth-0">HAL</a>
      {% endif %}
      {% if entry.bibtex_show %}
        <a
          href="#{{ entry_dom_id | escape }}-bibtex"
          class="bibtex btn btn-sm z-depth-0"
          role="button"
          data-bib-disclosure
          aria-controls="{{ entry_dom_id | escape }}-bibtex"
          aria-expanded="false"
        >Bib</a>
      {% endif %}
      {% if entry.html %}
        {% assign html_url = entry.html | safe_http_url %}
        {% assign html_path = entry.html | safe_local_asset_path %}
        {% if html_url and html_url != empty %}
          <a href="{{ html_url | escape }}" class="btn btn-sm z-depth-0">HTML</a>
        {% elsif html_path and html_path != empty %}
          <a href="{{ html_path | prepend: '/assets/html/' | relative_url | escape }}" class="btn btn-sm z-depth-0">HTML</a>
        {% endif %}
      {% endif %}
      {% if entry.pdf %}
        {% assign pdf_url = entry.pdf | safe_http_url %}
        {% assign pdf_path = entry.pdf | safe_local_asset_path %}
        {% if pdf_url and pdf_url != empty %}
          <a href="{{ pdf_url | escape }}" class="btn btn-sm z-depth-0">PDF</a>
        {% elsif pdf_path and pdf_path != empty %}
          <a href="{{ pdf_path | prepend: '/assets/pdf/' | relative_url | escape }}" class="btn btn-sm z-depth-0">PDF</a>
        {% endif %}
      {% endif %}
      {% if entry.supp %}
        {% assign supp_url = entry.supp | safe_http_url %}
        {% assign supp_path = entry.supp | safe_local_asset_path %}
        {% if supp_url and supp_url != empty %}
          <a href="{{ supp_url | escape }}" class="btn btn-sm z-depth-0">Supp</a>
        {% elsif supp_path and supp_path != empty %}
          <a href="{{ supp_path | prepend: '/assets/pdf/' | relative_url | escape }}" class="btn btn-sm z-depth-0">Supp</a>
        {% endif %}
      {% endif %}
      {% if video_url and video_url != empty and site.enable_video_embedding %}
        <button
          type="button"
          class="video-toggle btn btn-sm z-depth-0"
          data-bib-disclosure
          aria-controls="{{ entry_dom_id | escape }}-video"
          aria-expanded="false"
        >Video</button>
      {% elsif video_url and video_url != empty %}
        <a href="{{ video_url | escape }}" class="btn btn-sm z-depth-0">Video</a>
      {% endif %}
      {% if entry.blog %}
        {% assign blog_url = entry.blog | safe_link_url %}
        {% if blog_url and blog_url != empty %}<a href="{{ blog_url | escape }}" class="btn btn-sm z-depth-0">Blog</a>{% endif %}
      {% endif %}
      {% if entry.code %}
        {% assign code_url = entry.code | safe_link_url %}
        {% if code_url and code_url != empty %}<a href="{{ code_url | escape }}" class="btn btn-sm z-depth-0">Code</a>{% endif %}
      {% endif %}
      {% if entry.poster %}
        {% assign poster_url = entry.poster | safe_http_url %}
        {% assign poster_path = entry.poster | safe_local_asset_path %}
        {% if poster_url and poster_url != empty %}
          <a href="{{ poster_url | escape }}" class="btn btn-sm z-depth-0">Poster</a>
        {% elsif poster_path and poster_path != empty %}
          <a href="{{ poster_path | prepend: '/assets/pdf/' | relative_url | escape }}" class="btn btn-sm z-depth-0">Poster</a>
        {% endif %}
      {% endif %}
      {% if entry.slides %}
        {% assign slides_url = entry.slides | safe_http_url %}
        {% assign slides_path = entry.slides | safe_local_asset_path %}
        {% if slides_url and slides_url != empty %}
          <a href="{{ slides_url | escape }}" class="btn btn-sm z-depth-0">Slides</a>
        {% elsif slides_path and slides_path != empty %}
          <a href="{{ slides_path | prepend: '/assets/pdf/' | relative_url | escape }}" class="btn btn-sm z-depth-0">Slides</a>
        {% endif %}
      {% endif %}
      {% if entry.website %}
        {% assign website_url = entry.website | safe_link_url %}
        {% if website_url and website_url != empty %}<a href="{{ website_url | escape }}" class="btn btn-sm z-depth-0">Website</a>{% endif %}
      {% endif %}
      {%- comment -%} zhw.li: custom burgundy Google Scholar button, inline with the other link buttons {%- endcomment -%}
      {% assign scholar_user_id = site.data.socials.scholar_userid | safe_publication_identifier %}
      {% assign publication_id = entry.google_scholar_id | safe_publication_identifier %}
      {% if site.enable_publication_badges.google_scholar and scholar_user_id and scholar_user_id != empty and publication_id and publication_id != empty %}
        {% assign citation_count = 0 %}
        {% assign scholar_id_key = scholar_user_id | append: ':' | append: publication_id %}
        {% assign publication_key = publication_id %}
        {% if site.data.citations.papers[scholar_id_key] %}
          {% assign citation_count = site.data.citations.papers[scholar_id_key].citations %}
        {% elsif site.data.citations.papers[publication_key] %}
          {% assign citation_count = site.data.citations.papers[publication_key].citations %}
        {% else %}
          {% for paper in site.data.citations.papers %}
            {% assign paper_key = paper[0] %}
            {% assign paper_publication_id = paper_key | split: ':' | last %}
            {% if paper_publication_id == publication_id %}
              {% assign citation_count = paper[1].citations %}
              {% break %}
            {% endif %}
          {% endfor %}
        {% endif %}
        {% assign scholar_user_id_encoded = scholar_user_id | url_encode %}
        {% assign publication_id_encoded = publication_id | url_encode %}
        <a
          href="https://scholar.google.com/citations?view_op=view_citation&amp;hl=en&amp;user={{ scholar_user_id_encoded | escape }}&amp;citation_for_view={{ scholar_user_id_encoded | escape }}%3A{{ publication_id_encoded | escape }}"
          class="scholar-citations btn btn-sm z-depth-0"
          aria-label="{{ citation_count | escape }} Google Scholar citations"
          target="_blank"
          rel="external nofollow noopener"
        >
          <i class="ai ai-google-scholar"></i>
          <span class="scholar-citation-count">{{ citation_count | escape }}</span>
        </a>
      {% endif %}
    </div>
    {% if site.enable_publication_badges %}
      {% assign altmetric_id = entry.altmetric | safe_publication_identifier %}
      {% assign dimensions_id = entry.dimensions | safe_publication_identifier %}
      {% assign eprint_id = entry.eprint | safe_publication_identifier %}
      {% assign pmid_id = entry.pmid | safe_publication_identifier %}
      {% assign isbn_id = entry.isbn | safe_publication_identifier %}
      {% assign inspirehep_id = entry.inspirehep_id | safe_publication_identifier %}
      {% assign entry_has_altmetric_badge = false %}
      {% if entry.altmetric == 'true' or altmetric_id and altmetric_id != empty %}
        {% assign entry_has_altmetric_badge = true %}
      {% endif %}

      {% assign entry_has_dimensions_badge = false %}
      {% if entry.dimensions == 'true' or dimensions_id and dimensions_id != empty %}
        {% assign entry_has_dimensions_badge = true %}
      {% endif %}

      {%- comment -%} zhw.li: scholar badge is rendered inline in .links, not in .badges {%- endcomment -%}
      {% assign entry_has_google_scholar_badge = false %}

      {% assign entry_has_inspirehep_badge = false %}
      {% if inspirehep_id and inspirehep_id != empty %}
        {% assign entry_has_inspirehep_badge = true %}
      {% endif %}
      {% if entry_has_altmetric_badge or entry_has_dimensions_badge or entry_has_google_scholar_badge or entry_has_inspirehep_badge %}
        <div class="badges">
          {% if site.enable_publication_badges.altmetric and entry_has_altmetric_badge %}
            <span
              class="altmetric-embed"
              data-badge-type="2"
              data-badge-popover="right"
              {% if altmetric_id and altmetric_id != empty and entry.altmetric != 'true' %}
                data-altmetric-id="{{ altmetric_id | escape }}"
              {% elsif arxiv_id and arxiv_id != empty %}
                data-arxiv-id="{{ arxiv_id | escape }}"
              {% elsif eprint_id and eprint_id != empty %}
                data-arxiv-id="{{ eprint_id | escape }}"
              {% elsif doi_id and doi_id != empty %}
                data-doi="{{ doi_id | escape }}"
              {% elsif pmid_id and pmid_id != empty %}
                data-pmid="{{ pmid_id | escape }}"
              {% elsif isbn_id and isbn_id != empty %}
                data-isbn="{{ isbn_id | escape }}"
              {% endif %}
            ></span>
          {% endif %}
          {% if site.enable_publication_badges.dimensions and entry_has_dimensions_badge %}
            <span
              class="__dimensions_badge_embed__"
              {% if dimensions_id and dimensions_id != empty and entry.dimensions != 'true' %}
                data-id="{{ dimensions_id | escape }}"
              {% elsif doi_id and doi_id != empty %}
                data-doi="{{ doi_id | escape }}"
              {% elsif pmid_id and pmid_id != empty %}
                data-pmid="{{ pmid_id | escape }}"
              {% endif %}
              data-style="small_rectangle"
              data-legend="hover-right"
              style="margin-bottom: 3px;"
            ></span>
          {% endif %}
          {% if site.enable_publication_badges.inspirehep and entry_has_inspirehep_badge %}
            {% capture inspirehep_count %}{% inspirehep_citations entry.inspirehep_id %}{% endcapture %}
            {% assign inspirehep_count = inspirehep_count | strip %}
            <a
              href="https://inspirehep.net/literature/{{ inspirehep_id | escape }}"
              aria-label="Inspirehep link"
            >
              <img
                src="https://img.shields.io/badge/inspire-{{ inspirehep_count | url_encode | escape }}-001628?logo=inspire&amp;logoColor=001628&amp;labelColor=beige"
                alt="{{ inspirehep_count | escape }} InspireHEP citations"
              >
            </a>
          {% endif %}
        </div>
      {% endif %}
    {% endif %}

    {% if entry.award %}
      <!-- Hidden Award block -->
      <div id="{{ entry_dom_id | escape }}-award" class="award hidden d-print-inline">
        <p>{{ entry.award | markdownify }}</p>
      </div>
    {% endif %}

    {% if entry.abstract %}
      <!-- Hidden abstract block -->
      <div id="{{ entry_dom_id | escape }}-abstract" class="abstract hidden">
        <p>{{ entry.abstract }}</p>
      </div>
    {% endif %}

    {% if entry.bibtex_show %}
      <!-- Hidden bibtex block -->
      <div id="{{ entry_dom_id | escape }}-bibtex" class="bibtex hidden">
        {% capture bibtex_code %}
          {% highlight bibtex %}
          {{- entry.bibtex | hideCustomBibtex -}}
          {% endhighlight %}
        {% endcapture %}
        {{ bibtex_code | replace: '<pre', '<pre tabindex="0" aria-label="BibTeX citation"' }}
      </div>
    {% endif %}

    {% if video_url and video_url != empty and site.enable_video_embedding %}
      <!-- Hidden video block -->
      <div id="{{ entry_dom_id | escape }}-video" class="abstract video hidden">
        <div style="text-align: center;">{% include video.liquid path=video_url class="img-fluid rounded z-depth-1" controls=true %}</div>
      </div>
    {% endif %}
  </div>
</div>
