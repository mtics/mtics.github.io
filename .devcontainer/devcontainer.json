// For format details, see https://aka.ms/devcontainer.json. For config options, see the
// README at: https://github.com/devcontainers/templates/tree/main/src/jekyll
{
  "name": "Jekyll",
  // Using a Dockerfile to fix the broken Yarn repository. See issue #3487.
  "build": {
    "dockerfile": "Dockerfile"
  },

  "remoteEnv": {
    "PATH": "/home/vscode/.local/bin:/usr/local/bundle/bin:/usr/local/bin:${containerEnv:PATH}"
  },

  "postCreateCommand": "bundle _2.6.9_ install --jobs 4 --retry 3 && npm ci && python3 -m pip install --user --break-system-packages --require-hashes -r requirements-build.txt",

  "postStartCommand": "./bin/devcontainer_start.sh",

  "customizations": {
    "vscode": {
      "extensions": [
        "esbenp.prettier-vscode",
        "sissel.shopify-liquid",
        "yzhang.markdown-all-in-one"
      ],
      "settings": {
        // use prettier code formatter as default formatter
        "editor.defaultFormatter": "esbenp.prettier-vscode",
        "prettier.configPath": ".prettierrc",
        "editor.formatOnSave": true
      }
    }
  },

  "remoteUser": "vscode"
}
